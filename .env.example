# Docker Configuration
COMPOSE_PROJECT_NAME=laravel
DOCKER_SERVER_NAME=laravel.test
UID=1000
GID=1000

# Docker Port Mappings
DOCKER_NGINX_LOCAL_PORT=40443
DOCKER_MYSQL_LOCAL_PORT=43306
DOCKER_MYSQL_TEST_LOCAL_PORT=43307
DOCKER_REDIS_LOCAL_PORT=46379
DOCKER_REVERB_LOCAL_PORT=48080
DOCKER_MAILPIT_SMTP_LOCAL_PORT=41025
DOCKER_MAILPIT_WEB_LOCAL_PORT=48025
DOCKER_LOCALSTACK_LOCAL_PORT=44566

# Laravel Application
APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL="https://api.${DOCKER_SERVER_NAME}:${DOCKER_NGINX_LOCAL_PORT}"

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=app
DB_PASSWORD=app

# Cache & Queue
BROADCAST_CONNECTION=reverb
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail (Mailpit)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@${DOCKER_SERVER_NAME}"
MAIL_FROM_NAME="${APP_NAME}"

# Reverb (WebSockets)
REVERB_APP_ID=app-id
REVERB_APP_KEY=app-key
REVERB_APP_SECRET=app-secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# AWS/LocalStack (S3 Emulation)
AWS_ENDPOINT="https://api.${DOCKER_SERVER_NAME}:${DOCKER_LOCALSTACK_LOCAL_PORT}"
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET="${COMPOSE_PROJECT_NAME}-local"
AWS_USE_PATH_STYLE_ENDPOINT=true
