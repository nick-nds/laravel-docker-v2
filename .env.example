# =============================================================================
# Docker configuration
# =============================================================================
COMPOSE_PROJECT_NAME=laravel
DOCKER_SERVER_NAME=laravel.test
UID=1000
GID=1000

# Override to pin a different PHP minor (e.g. 8.3)
PHP_VERSION=8.4

# Host port mappings
DOCKER_NGINX_HTTP_PORT=8000
DOCKER_NGINX_HTTPS_PORT=40443
DOCKER_MYSQL_LOCAL_PORT=43306
DOCKER_MYSQL_TEST_PORT=43307
DOCKER_REDIS_LOCAL_PORT=46379
DOCKER_MAILPIT_SMTP_PORT=41025
DOCKER_MAILPIT_WEB_PORT=48025
DOCKER_MINIO_API_PORT=49000
DOCKER_MINIO_CONSOLE_PORT=49001
DOCKER_REVERB_LOCAL_PORT=48080

# Xdebug mode on the container (trigger-only by default; override to disable in CI)
XDEBUG_MODE=debug,develop,coverage

# =============================================================================
# Laravel application
# =============================================================================
APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL="https://${DOCKER_SERVER_NAME}:${DOCKER_NGINX_HTTPS_PORT}"

LOG_CHANNEL=stack
LOG_LEVEL=debug

# =============================================================================
# Database (MySQL default — see README "Switching to PostgreSQL" to override)
# =============================================================================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=app
DB_PASSWORD=app
DB_ROOT_PASSWORD=root
DB_TEST_DATABASE=laravel_testing

# =============================================================================
# Cache / Queue / Session / Broadcast
# =============================================================================
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
BROADCAST_CONNECTION=log

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================================================
# Mail (Mailpit)
# =============================================================================
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@${DOCKER_SERVER_NAME}"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# S3-compatible object storage (MinIO)
# =============================================================================
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=localsecret
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=laravel-local
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# =============================================================================
# Reverb (optional, --profile reverb)
# =============================================================================
REVERB_APP_ID=app-id
REVERB_APP_KEY=app-key
REVERB_APP_SECRET=app-secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
